# Flask配置
SECRET_KEY=your-secret-key-change-in-production
FLASK_ENV=development

# 本地主数据库配置
# 桌面版建议保留 SQLite 作为本地主库，不要改成线上 MySQL。
DATABASE_URL=sqlite:///ai_monitor.db

# 云端 API 镜像同步
# 开启后，本地 SQLite 仍然是主库；客户端只调用 HTTPS API，不持有 MySQL 权限。
# GEO_CLOUD_SYNC_ENABLED=1
# GEO_REQUIRE_LOGIN=1
# GEO_CLOUD_SYNC_URL=https://geo.allgood.cn/api
# GEO_CLOUD_SYNC_TOKEN=replace-with-user-or-install-token
# 默认不上传 AI API Key；只有明确需要托管云分析时再开启。
# GEO_CLOUD_SYNC_KEYS=0

# PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost/ai_monitor

# Redis配置（用于Celery任务队列）
REDIS_URL=redis://localhost:6379/0

# 应用配置
DEBUG=True
HOST=0.0.0.0
PORT=5000
